// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Post {
  id              Int      @id @default(autoincrement())
  slug            String   @unique
  title           String
  content         String
  authorId        Int
  fieldofInterest String[]

  applicants Int[]
  teamSize   TeamSize    @default(FOUR)

  comments Int[]
  likes    Int[]

  isPublished Boolean
  views       Int      @default(0)
  isDeleted   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Applicant {
  id     Int @id @default(autoincrement())
  postId Int
  userId Int // application id

  motivation            String // What impressed you to join
  contribution          String // What you bring to the table
  learningGoals         String // What you want to learn
  weeklyCommitmentHours Int // Hours per week
  longTermInterest      Boolean // Willing for long term?

  applicationStatus ApplicationStatus @default(PENDING)
  role              Role              @default(APPLICANT)
  

  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([postId, userId])
}

model Comments {
  id      Int @id @default(autoincrement())
  postId  Int
  userId  Int
  content String

  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Likes {
  id      Int @id @default(autoincrement())
  postId  Int
  userId  Int

  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum TeamSize {
  ONE
  TWO
  THREE
  FOUR
  FIVE
  SIX
  SEVEN
  EIGHT
  NINE
  TEN
  TEN_PLUS
}
  
enum ApplicationStatus {
  PENDING // expressed interest, awaiting review
  UNDER_REVIEW // owner is reviewing
  APPROVED // accepted into the idea
  REJECTED // not selected
  WITHDRAWN // applicant pulled out
}

enum Role {
  OWNER
  MENTOR
  APPLICANT
}
